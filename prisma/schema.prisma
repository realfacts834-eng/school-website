generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. سائٹ سیٹنگز
// ==========================================
model SiteSetting {
  id              String   @id @default(cuid())
  schoolName      String   @default("Afridi Model School & College")
  tagline         String?
  logo            String?
  logoWhite       String?
  favicon         String?
  ogImage         String?
  primaryColor    String   @default("#0F172A")
  secondaryColor  String   @default("#3B82F6")
  accentColor     String   @default("#D4AF37")
  email           String?
  phone           String?
  altPhone        String?
  whatsapp        String?
  address         String?
  mapEmbedUrl     String?
  officeTiming    String?
  facebook        String?
  twitter         String?
  instagram       String?
  youtube         String?
  linkedin        String?
  metaTitle       String?
  metaDescription String?
  googleAnalytics String?
  updatedAt       DateTime @updatedAt
}

// ==========================================
// 2. ایڈمن یوزرز - NextAuth
// ==========================================
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("admin")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  news     News[]
  events   Event[]
  blog     Blog[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

// ==========================================
// 3. خبریں
// ==========================================
model News {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String?
  featuredImage String?
  isPublished   Boolean  @default(false)
  isBreaking    Boolean  @default(false)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// 4. بلاگ
// ==========================================
model Blog {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  content       String
  excerpt       String?
  featuredImage String?
  isPublished   Boolean  @default(false)
  authorId      String
  author        User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  tags          String?
  viewCount     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// 5. تقریبات
// ==========================================
model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  date        DateTime
  endDate     DateTime?
  time        String?
  location    String?
  image       String?
  isPublished Boolean  @default(false)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 6. گیلری
// ==========================================
model Gallery {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String?
  coverImage  String?
  isPublished Boolean        @default(false)
  images      GalleryImage[]
  createdAt   DateTime       @default(now()) // یہاں فکس کر دیا ہے!
  updatedAt   DateTime       @updatedAt
}

model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  albumId   String
  album     Gallery  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

// ==========================================
// 7. اساتذہ
// ==========================================
model Faculty {
  id            String   @id @default(cuid())
  name          String
  designation   String
  qualification String?
  experience    String?
  image         String?
  bio           String?
  email         String?
  phone         String?
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ==========================================
// 8. داخلے
// ==========================================
model Admission {
  id             String   @id @default(cuid())
  studentName    String
  fatherName     String
  motherName     String?
  dob            DateTime
  gender         String
  applyingClass  String
  previousSchool String?
  address        String
  phone          String
  email          String?
  status         String   @default("pending")
  remarks        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==========================================
// 9. نوٹس بورڈ
// ==========================================
model Notice {
  id          String   @id @default(cuid())
  title       String
  content     String?
  fileUrl     String?
  isUrgent    Boolean  @default(false)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 10. نتائج
// ==========================================
model Result {
  id          String   @id @default(cuid())
  title       String
  class       String
  examType    String
  fileUrl     String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// 11. رابطہ فارم
// ==========================================
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ==========================================
// 12. سبسکرائبرز
// ==========================================
model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ==========================================
// 13. FAQ
// ==========================================
model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 14. پیج ویوز
// ==========================================
model PageView {
  id        String   @id @default(cuid())
  page      String
  referrer  String?
  country   String?
  device    String?
  createdAt DateTime @default(now())
}
