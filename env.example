# ==========================================
# SCHOOL WEBSITE - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env.local and fill in your values
# cp env.example .env.local
# ==========================================

# ==========================================
# 1. DATABASE (PostgreSQL)
# ==========================================
# Local PostgreSQL
# DATABASE_URL="postgresql://postgres:password@localhost:5432/school_website"
#
# Neon (Serverless PostgreSQL) - Recommended for production
# DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/dbname?sslmode=require"
#
# Supabase
# DATABASE_URL="postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres"
DATABASE_URL="postgresql://user:password@localhost:5432/school_website"

# ==========================================
# 2. AUTHENTICATION (NextAuth v5)
# ==========================================
# Generate a random secret: openssl rand -base64 32
# Or use: https://generate-secret.vercel.app/32
NEXTAUTH_SECRET="generate-a-random-32-character-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# 3. APPLICATION URL
# ==========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ==========================================
# 4. CLOUDINARY (Image/File Upload)
# ==========================================
# Sign up at https://cloudinary.com (Free tier: 25GB)
# Get credentials from: https://console.cloudinary.com/
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ==========================================
# 5. RESEND (Email Service)
# ==========================================
# Sign up at https://resend.com (Free tier: 100 emails/day)
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Admin email for notifications
ADMIN_EMAIL="admin@yourdomain.com"

# ==========================================
# 6. GOOGLE ANALYTICS
# ==========================================
# Get Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# ==========================================
# 7. (OPTIONAL) GOOGLE SITE VERIFICATION
# ==========================================
# For Google Search Console
# NEXT_PUBLIC_GOOGLE_VERIFICATION="your-verification-code"

# ==========================================
# 8. (OPTIONAL) DEPLOYMENT
# ==========================================
# Vercel: Auto-detected
# For other platforms:
# NODE_ENV="production"
# PORT=3000

# ==========================================
# GENERATING SECRETS:
# ==========================================
# NEXTAUTH_SECRET:
#   Mac/Linux: openssl rand -base64 32
#   Windows:   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   Online:    https://generate-secret.vercel.app/32
# ==========================================